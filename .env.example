# Flutter 앱에 포함되는 공개 설정입니다.
# 비밀 키는 모바일 앱 .env에 넣지 말고 server/ 프록시 환경변수로만 설정하세요.

# 로컬 프록시 주소
# - iOS Simulator / macOS / web: http://127.0.0.1:8080
# - Android Emulator: http://10.0.2.2:8080
# - Physical device: http://<개발 머신 LAN IP>:8080 또는 배포된 HTTPS URL
SIKDANSCAN_PROXY_BASE_URL=http://127.0.0.1:8080

# 프록시 서버에 PROXY_CLIENT_TOKEN을 설정했다면 같은 값을 넣으세요.
# 모바일 앱에 포함되는 값이므로 실서비스에서는 사용자 인증/App Check와 함께 사용하세요.
# SIKDANSCAN_PROXY_CLIENT_TOKEN=replace_with_non_secret_client_token

# 서버 비밀값은 .env.proxy.example을 복사해 .env.proxy에 설정하세요.
